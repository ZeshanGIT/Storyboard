{
  "name": "@onespec-dev/cli",
  "version": "0.1.0",
  "description": "OneSpec wireframe + product spec CLI",
  "type": "module",
  "license": "MIT",
  "homepage": "https://onespec.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZeshanGIT/Storyboard.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "onespec": "./dist/bin/onespec.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && rm -rf dist/templates && cp -r src/templates dist/templates",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@onespec-dev/spec": "0.1.0",
    "@onespec-dev/shell": "0.1.0",
    "commander": "^14.0.0",
    "vite": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "~6.0.2",
    "vitest": "^3.2.6"
  }
}
