{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@shell/*": ["./src/*"]
    }
  },
  "include": [
    "src/index.ts",
    "src/client.ts",
    "src/publish-ambient.d.ts",
    "src/json/**/*",
    "src/plugin/**/*",
    "src/types/**/*",
    "src/vite/**/*",
    "src/shell/**/*",
    "src/runtime/**/*",
    "src/components/**/*",
    "src/lib/app-url.ts",
    "src/lib/app-routes.ts",
    "src/lib/app-base-path.ts"
  ],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
