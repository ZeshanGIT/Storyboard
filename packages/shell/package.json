{
  "name": "@onespec-dev/shell",
  "version": "0.1.0",
  "description": "Storyboard wireframe preview, prototype, and graph dev server",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZeshanGIT/Storyboard.git",
    "directory": "packages/shell"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./vite": {
      "types": "./src/vite/index.ts",
      "import": "./src/vite/index.ts"
    },
    "./detect-mode": {
      "types": "./src/vite/detect-mode.ts",
      "import": "./src/vite/detect-mode.ts"
    },
    "./json/build-json-document": {
      "types": "./dist/json/build-json-document.d.ts",
      "import": "./dist/json/build-json-document.js"
    }
  },
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@dagrejs/dagre": "^3.0.0",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@xyflow/react": "^12.11.1",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "tailwindcss": "^4.3.1",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^3.2.6"
  }
}
