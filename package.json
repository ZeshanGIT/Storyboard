{
  "name": "storyboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build:packages": "npm run build -w @storyboard/spec -w @storyboard/shell -w storyboard",
    "build": "npm run build:packages && npm run codegen && tsc -b && vite build",
    "build:pages": "npm run build && cp dist/index.html dist/404.html",
    "check": "npm run codegen && tsc -b && biome check .",
    "fix": "biome check --write .",
    "codegen": "tsx src/plugin/run-codegen.ts",
    "archive-skills": "bash scripts/archive-skills.sh",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "storyboard": "tsx src/product-spec/cli/main.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@dagrejs/dagre": "^3.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@monaco-editor/react": "^4.7.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.3.1",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-mdx": "^3.1.1",
    "shadcn": "^4.11.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@mdx-js/language-service": "^0.7.3",
    "@mdx-js/typescript-plugin": "^0.1.3",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^3.2.6"
  }
}
