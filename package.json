{
  "name": "wireframex",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run codegen && tsc -b && vite build",
    "check": "npm run codegen && tsc -b && biome check .",
    "fix": "biome check --write .",
    "codegen": "tsx src/plugin/run-codegen.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@tailwindcss/vite": "^4.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@mdx-js/language-service": "^0.7.3",
    "@mdx-js/typescript-plugin": "^0.1.3",
    "@types/mdast": "^4.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "remark": "^15.0.1",
    "remark-mdx": "^3.1.1",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "unist-util-visit": "^5.1.0",
    "vite": "^8.1.0",
    "vitest": "^3.2.6"
  }
}
